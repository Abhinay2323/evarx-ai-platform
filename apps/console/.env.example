# Copy to .env.local for development. Vercel injects these in production.

# Supabase project — get from https://app.supabase.com/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Backend API base. Production: https://api.evarx.in
NEXT_PUBLIC_API_URL=https://api.evarx.in

# Marketing site (used for "back to evarx.in" links)
NEXT_PUBLIC_MARKETING_URL=https://evarx.in
