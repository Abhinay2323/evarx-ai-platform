# Copy to .env for local dev. Never commit real secrets.

# Runtime
ENV=dev
LOG_LEVEL=INFO
PORT=8000

# CORS — comma-separated, no trailing slash
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://evarx.in,https://www.evarx.in,https://app.evarx.in

# Postgres (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://evarx:evarx@localhost:5432/evarx

# Redis
REDIS_URL=redis://localhost:6379/0

# Supabase (auth + JWT verification). Pull from Supabase dashboard once project is created.
# SUPABASE_URL=https://<project>.supabase.co
# SUPABASE_JWT_SECRET=<from Project Settings → API → JWT Secret>
# SUPABASE_SERVICE_ROLE_KEY=<service_role key — server only, never ship to frontend>

# AWS S3 (ap-south-1 / Mumbai for DPDP residency)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=evarx-data-prod
# S3_REGION=ap-south-1

# Model providers (added in phase 1)
# ANTHROPIC_API_KEY=
# LITELLM_BASE_URL=http://litellm:4000

# Observability
# SENTRY_DSN=
