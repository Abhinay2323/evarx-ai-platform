# Copy this to `.env` on the production box and fill in the real values.
# This file is what `docker-compose.prod.yml` reads via --env-file.

# ---- Domain ----
# DNS A record for this name must point at this box's public IP.
API_DOMAIN=api.evarx.in

# Browser origins allowed to hit the API (comma-separated, no trailing slash).
ALLOWED_ORIGINS=https://evarx.in,https://www.evarx.in,https://app.evarx.in

# ---- Postgres ----
POSTGRES_USER=evarx
POSTGRES_DB=evarx
# Strong random — generate with: openssl rand -base64 32
POSTGRES_PASSWORD=

# ---- LiteLLM proxy auth ----
# Strong random — generate with: openssl rand -hex 32
# The API uses this to authenticate to the proxy. Never expose to frontend.
LITELLM_MASTER_KEY=

# ---- Model providers ----
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ---- Supabase auth (Phase 2.1+) ----
# JWT secret from Supabase: Project Settings → API → JWT Secret.
SUPABASE_URL=
SUPABASE_JWT_SECRET=
# Only set if a server-side admin op needs it (Phase 2.3+).
# SUPABASE_SERVICE_ROLE_KEY=

# ---- AWS S3 (Phase 2.2 — document storage) ----
# IAM user `evarx-api-s3` scoped to bucket `evarx-docs-prod`.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=evarx-docs-prod

# ---- SMTP (Phase 2.4 — invite emails) ----
# Optional. If unset, invites still work but admin shares the link manually.
# Resend example:    SMTP_HOST=smtp.resend.com  SMTP_PORT=587  SMTP_USERNAME=resend  SMTP_PASSWORD=<api_key>
# SES Mumbai example: SMTP_HOST=email-smtp.ap-south-1.amazonaws.com  SMTP_PORT=587  SMTP_USERNAME=<key>  SMTP_PASSWORD=<secret>
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=Evarx <noreply@evarx.in>
# SMTP_USE_TLS=true   # STARTTLS (port 587)
# SMTP_USE_SSL=false  # SMTPS    (port 465 — leave false unless you really need it)

# Public URL of the console — invite emails link here.
CONSOLE_URL=https://app.evarx.in

# ---- Observability ----
LOG_LEVEL=INFO
# SENTRY_DSN=https://...
