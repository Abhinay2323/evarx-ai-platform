# Copy this to `.env` on the production box and fill in the real values.
# This file is what `docker-compose.prod.yml` reads via --env-file.

# ---- Domain ----
# DNS A record for this name must point at this box's public IP.
API_DOMAIN=api.evarx.in

# Browser origins allowed to hit the API (comma-separated, no trailing slash).
ALLOWED_ORIGINS=https://evarx.in,https://www.evarx.in,https://app.evarx.in

# ---- Postgres ----
POSTGRES_USER=evarx
POSTGRES_DB=evarx
# Strong random — generate with: openssl rand -base64 32
POSTGRES_PASSWORD=

# ---- LiteLLM proxy auth ----
# Strong random — generate with: openssl rand -hex 32
# The API uses this to authenticate to the proxy. Never expose to frontend.
LITELLM_MASTER_KEY=

# ---- Model providers ----
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ---- Supabase auth (Phase 2.1+) ----
# JWT secret from Supabase: Project Settings → API → JWT Secret.
SUPABASE_URL=
SUPABASE_JWT_SECRET=
# Only set if a server-side admin op needs it (Phase 2.3+).
# SUPABASE_SERVICE_ROLE_KEY=

# ---- AWS S3 (Phase 2.2 — document storage) ----
# IAM user `evarx-api-s3` scoped to bucket `evarx-docs-prod`.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=evarx-docs-prod

# ---- Observability ----
LOG_LEVEL=INFO
# SENTRY_DSN=https://...
